# FinRelief AI — Environment Variables Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The server loads .env automatically on startup (via python-dotenv).
#
#   cp .env.example .env
#   # then edit .env with your real keys
# ──────────────────────────────────────────────────────────────────────────────

# ── Gemini API Key (required for AI-generated letters) ────────────────────────
# Get yours free at: https://aistudio.google.com/app/apikey
# If not set, the app still works — letters fall back to a professional template.
GEMINI_API_KEY=your_gemini_api_key_here

# ── JWT Secret Key (required — change before any public deployment) ────────────
# Generate a strong one:
#   python -c "import secrets; print(secrets.token_hex(32))"
FINRELIEF_SECRET_KEY=your_generated_secret_key_here
